{
  "name": "blood-donation-system",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@blood-donation/web",
    "dev:server": "turbo run dev --filter=@blood-donation/server",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "seed:demo": "turbo run seed:demo --filter=@blood-donation/server",
    "db:generate": "turbo run db:generate --filter=@blood-donation/server",
    "db:migrate": "turbo run db:migrate --filter=@blood-donation/server",
    "db:push": "turbo run db:push --filter=@blood-donation/server",
    "db:reset": "turbo run db:reset --filter=@blood-donation/server"
  },
  "devDependencies": {
    "turbo": "^2.6.3",
    "typescript": "^5"
  }
}
